.claude/
# Root hardware-configuration.nix (legacy, before flakes)
/hardware-configuration.nix
# Allow hardware configs in hosts/ subdirectories (needed for flakes)
!hosts/*/hardware-configuration.nix
# nix build / nixos-rebuild output symlinks
/result
/result-*
/n-boot
# Accidental HOME-as-literal-tilde dir (e.g. from a script run with $HOME="~")
/~/
